# =============================================================================
# DEWEB Backend — copy to .env and fill in your values
# cp .env.example .env
# =============================================================================

# --- Server (required) ---
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:8001
PUBLIC_WEB_URL=https://dewebam.com
DATABASE_PATH=./data/deweb.sqlite

# =============================================================================
# Email (required for registration verification & lead notifications)
# Gmail: use an App Password (16 chars), not your normal password
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=your@gmail.com

# =============================================================================
# Admin
# =============================================================================

ADMIN_GMAIL=your@gmail.com
ADMIN_PASSWORD=your-site-password-here
ADMIN_AUTO_LOGIN=false
ADMIN_EMAILS=your@gmail.com
ADMIN_NOTIFY_EMAIL=your@gmail.com

# Optional AI support
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Social links (Contact page — restart API after changes)
# =============================================================================

SOCIAL_LINK_LINKEDIN=
SOCIAL_LINK_INSTAGRAM=
SOCIAL_LINK_TELEGRAM=https://t.me/dewebam
SOCIAL_LINK_X=
