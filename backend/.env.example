# DeWeb Backend — copy to .env and fill in values

# Server
PORT=3000
JWT_SECRET=change-me
CORS_ORIGIN=http://localhost:3001
PUBLIC_WEB_URL=http://localhost:3001
DATABASE_PATH=./data/deweb.sqlite
SITE_URL=https://dewebam.com
NEXT_PUBLIC_SITE_URL=https://dewebam.com

# Admin
ADMIN_GMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NOTIFY_EMAIL=admin@example.com

# OpenAI (content + image generation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# =============================================================================
# DeWebam Telegram Bot
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USER_ID=
# Production: use webhook (stops polling conflicts). Dev: leave empty to poll locally.
TELEGRAM_WEBHOOK_URL=https://dewebam.com/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=change-me-random-secret

# =============================================================================
# LinkedIn OAuth + Publishing
# App: https://www.linkedin.com/developers/
# Add redirect URL: https://dewebam.com/api/linkedin/callback
# =============================================================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://dewebam.com/api/linkedin/callback
# Default: w_member_social only (OAuth works; profile ID needs setup or Sign In product)
LINKEDIN_OAUTH_SCOPES=w_member_social
# After adding "Sign In with LinkedIn using OpenID Connect" in Developer Portal:
# LINKEDIN_OAUTH_SCOPES=openid profile w_member_social
# If LinkedIn approves company posting:
# LINKEDIN_OAUTH_SCOPES=w_member_social w_organization_social r_organization_social
LINKEDIN_OAUTH_SETUP_KEY=
LINKEDIN_ORGANIZATION_URN=urn:li:organization:YOUR_ORG_ID
LINKEDIN_PERSON_URN=
# Legacy manual token (optional if using OAuth)
LINKEDIN_ACCESS_TOKEN=

# =============================================================================
# Facebook + Instagram Publishing (Meta Graph API)
# Create app: https://developers.facebook.com/
# Instagram requires Business/Creator account linked to Facebook Page
# =============================================================================
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# =============================================================================
# X (Twitter) Publishing — posts to @dewebam via DeWebam Telegram bot
# Create app: https://developer.x.com/ → User authentication → OAuth 1.0a
# App permissions: Read and write
# =============================================================================
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Optional OAuth 2.0 user bearer fallback (tweet.write scope)
X_BEARER_TOKEN=

# Public profile links (shown after publish)
SOCIAL_LINK_LINKEDIN=
SOCIAL_LINK_INSTAGRAM=
SOCIAL_LINK_FACEBOOK=
SOCIAL_LINK_X=https://x.com/dewebam

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
