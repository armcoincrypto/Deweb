PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret
CORS_ORIGIN=http://localhost:8001
DATABASE_PATH=./data/deweb.sqlite

# Your external swap website (users buy/sell crypto ↔ DEWEB)
SWAP_SITE_BUY_URL=https://your-swap-site.com/buy
SWAP_SITE_SELL_URL=https://your-swap-site.com/sell
SWAP_WEBHOOK_SECRET=change-me-swap-webhook-secret

# Platform treasury wallets (crypto sent here → credit DEWEB via webhook)
TREASURY_USDT=
TREASURY_ETH=
TREASURY_BTC=
TREASURY_DASH=

# Optional: platform user id for service fees (defaults to guest)
PLATFORM_USER_ID=

# Email verification (when you add Resend/SendGrid)
# EMAIL_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com
