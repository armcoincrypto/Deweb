# =============================================================================
# DEWEB Backend — copy to .env and fill in your values
# cp .env.example .env
# =============================================================================

# --- Server (required) ---
PORT=3000
JWT_SECRET=
CORS_ORIGIN=http://localhost:8001
PUBLIC_WEB_URL=https://dewebam.com
DATABASE_PATH=./data/deweb.sqlite

# =============================================================================
# USDT treasury — separate address per wallet (users send USDT here)
# 1 USDT = 1 DEWEB = 1 USD
# =============================================================================

TREASURY_USDT_METAMASK=
TREASURY_USDT_RONIN=
USDT_CONTRACT_ETH=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDT_CONTRACT_RONIN=0x97a9107c1791bc656a31382e6A152ef171ad99cD

# Blockchain RPC (required for automatic USDT verification)
ETH_RPC_URL=
# Or use Alchemy / Infura:
ALCHEMY_API_KEY=
INFURA_PROJECT_ID=

RONIN_RPC_URL=https://api.roninchain.com/rpc
RONIN_CHAIN_ID=2020

# =============================================================================
# Email (required for wallet access — users must verify email)
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=your@gmail.com

# =============================================================================
# Optional swap site (withdraw / buy DEWEB outside wallet top-up)
# =============================================================================

SWAP_SITE_BUY_URL=
SWAP_SITE_SELL_URL=
SWAP_WEBHOOK_SECRET=

# =============================================================================
# Admin
# =============================================================================

ADMIN_GMAIL=your@gmail.com
ADMIN_PASSWORD=your-site-password-here
ADMIN_AUTO_LOGIN=false
ADMIN_EMAILS=your@gmail.com
ADMIN_NOTIFY_EMAIL=your@gmail.com
ADMIN_INITIAL_DEWEB=1000000
DEWEB_USD_RATE=1

# Optional AI support
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Social links (Contact page — restart API after changes: systemctl restart deweb-api)
# Leave empty to use built-in defaults on the website.
# =============================================================================

SOCIAL_LINK_LINKEDIN=
SOCIAL_LINK_INSTAGRAM=
SOCIAL_LINK_TELEGRAM=https://t.me/dewebam
SOCIAL_LINK_X=
