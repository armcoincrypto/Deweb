# =============================================================================
# DEWEB Backend — copy to .env and fill in your values
# cp .env.example .env
# =============================================================================

# --- Server (required) ---
PORT=3000
JWT_SECRET=
CORS_ORIGIN=http://localhost:8001
DATABASE_PATH=./data/deweb.sqlite

# =============================================================================
# MetaMask & Ronin — CONNECT BUTTON (no API key needed)
# Users install browser extensions only. Leave optional lines empty for now.
# =============================================================================

# Optional later: WalletConnect (mobile, Coinbase Wallet, etc.)
# Get free Project ID: https://cloud.walletconnect.com
WALLETCONNECT_PROJECT_ID=

# Ronin chain (only if users send/receive crypto on Ronin network)
RONIN_RPC_URL=https://api.roninchain.com/rpc
RONIN_CHAIN_ID=2020

# Ethereum RPC (only if you auto-detect ETH/USDT deposits on Ethereum)
# Free keys: https://www.alchemy.com or https://infura.io
RPC_URL=
ALCHEMY_API_KEY=
INFURA_PROJECT_ID=
ETHERSCAN_API_KEY=

# =============================================================================
# Your swap website (buy DEWEB / withdraw DEWEB → crypto)
# =============================================================================

SWAP_SITE_BUY_URL=
SWAP_SITE_SELL_URL=
SWAP_WEBHOOK_SECRET=

# Wallet top-ups: set to "false" to require admin approval before crediting DEWEB
TOPUP_AUTO_APPROVE=true

# =============================================================================
# Your treasury wallets — crypto users send TO YOU
# Shown in Wallet page + credited via swap webhook
# =============================================================================

# USDT only — wallet top-ups (1 USDT = 1 DEWEB = 1 USD)
TREASURY_USDT=
USDT_CONTRACT_ETH=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDT_CONTRACT_RONIN=0x97a9107c1791bc656a31382e6A152ef171ad99cD

# Optional legacy (not used for automatic top-up)
TREASURY_ETH=
TREASURY_BTC=
TREASURY_DASH=
TREASURY_RONIN=

# =============================================================================
# Email verification (optional — no 2FA)
# =============================================================================

EMAIL_API_KEY=
EMAIL_FROM=

# =============================================================================
# Other (optional)
# =============================================================================

PLATFORM_USER_ID=

# =============================================================================
# Admin — your Gmail + site password (auto-created on server start)
# Open http://localhost:8001/account.html → signs in automatically if AUTO_LOGIN is true
# =============================================================================

ADMIN_GMAIL=your@gmail.com
ADMIN_PASSWORD=your-site-password-here
ADMIN_AUTO_LOGIN=true

# Optional: partner admin emails (comma-separated)
ADMIN_EMAILS=your@gmail.com
ADMIN_INITIAL_DEWEB=1000000
DEWEB_USD_RATE=1

# Gmail SMTP — support urgent alerts (use App Password, NOT your normal Gmail password)
ADMIN_NOTIFY_EMAIL=your@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password

# Optional AI support (otherwise rule-based replies)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
